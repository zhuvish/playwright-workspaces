# Microsoft Playwright Service - Environment Variables
# Copy this file to .env and fill in your values

# Playwright Service (Required for all samples)
PLAYWRIGHT_SERVICE_URL=
PLAYWRIGHT_SERVICE_ACCESS_TOKEN=

# Azure OpenAI (Required for browser_use_remote.py only)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=


# =============================================================================
# OPTIONAL — Authenticated forward proxy
# Only if you switch the entry point in connectOverCDPScript.js /
# puppeteerScript.js / cdpUseScript.py to the `mainWithProxy()` /
# `main_with_proxy()` variant.
# =============================================================================
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
